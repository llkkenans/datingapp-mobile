# Uncomment this line to define a global platform for your project
# platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
    end
  end

  # Xcode 16 / macOS 15 + iCloud Desktop: writing to an iCloud-synced directory
  # adds com.apple.FinderInfo to frameworks, causing codesign to fail with
  # "resource fork, Finder information, or similar detritus not allowed".
  #
  # Two fixes needed:
  # 1. Add a Run Script phase to each Pod target that strips xattrs from the
  #    compiled framework before Xcode's implicit codesign step.
  # 2. Patch the embed-frameworks shell script to strip xattrs before each
  #    embedded framework is re-signed inside Runner.app/Frameworks/.

  installer.pods_project.targets.each do |target|
    next if target.name.start_with?('[CP]')
    strip_phase = target.new_shell_script_build_phase('Strip xattrs (iCloud Desktop fix)')
    strip_phase.shell_script = 'xattr -cr "${BUILT_PRODUCTS_DIR}/${FULL_PRODUCT_NAME}" 2>/dev/null || true'
    strip_phase.run_only_for_deployment_postprocessing = '0'
  end
  installer.pods_project.save

  frameworks_script = "#{installer.sandbox.root}/Target Support Files/Pods-Runner/Pods-Runner-frameworks.sh"
  if File.exist?(frameworks_script)
    content = File.read(frameworks_script)
    unless content.include?('xattr -cr')
      patched = content.gsub(
        "code_sign_if_enabled \"${destination}/$(basename \"$1\")\"",
        "xattr -cr \"${destination}/$(basename \"$1\")\" 2>/dev/null || true\n  code_sign_if_enabled \"${destination}/$(basename \"$1\")\""
      )
      File.write(frameworks_script, patched)
    end
  end
end
